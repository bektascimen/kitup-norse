    "react-native-screens": "~4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@kitup/eslint-config": "workspace:*",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.0.0",
    "@types/react": "~18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEach": [
      "<rootDir>/jest.setup.ts"
